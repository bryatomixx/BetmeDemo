# Private key de Vapi (Dashboard > API Keys > Private).
# Server-side: NUNCA usar prefijo NEXT_PUBLIC_ (expondría la llave al browser).
# Sin esta llave, el modulo de Llamadas del dashboard usa datos demo.
VAPI_PRIVATE_KEY=

# --- WhatsApp Cloud API (Meta) ---
# Verify token: lo inventas tú; debe coincidir con el del panel de Meta.
WHATSAPP_VERIFY_TOKEN=
# App Secret de la App de Meta (valida la firma X-Hub-Signature-256).
WHATSAPP_APP_SECRET=
# Para responder mensajes (no requeridos solo para recibir):
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Supabase (persistencia de mensajes de WhatsApp) ---
# Sin estas, los mensajes caen a un store en memoria (se pierden al reiniciar).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
