      "name": "Mapear datos confirmar",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "// Aqui conectas el agendamiento real (crear evento en el calendario o fila en BD).\nconst d = $json;\nreturn [{\n  json: {\n    agendada: true,\n    id_cita: 'CITA-' + Date.now(),\n    nombre: d.nombre || null,\n    telefono: d.telefono || null,\n    especialidad: d.especialidad || null,\n    fecha: d.fecha || null,\n    hora: d.hora || null,\n    medico: d.medico || null,\n    mensaje: 'Cita agendada correctamente.'\n  }\n}];"
      },
      "id": "code-conf",
      "name": "Agendar cita",
      "type": "n8n-nodes-base.code",
