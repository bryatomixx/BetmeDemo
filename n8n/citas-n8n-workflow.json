          ]
        },
        "options": {}
      },
      "id": "set-disp",
      "name": "Mapear datos disponibilidad",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [240, 0]
    },
    {
      "parameters": {
        "jsCode": "// Aqui conectas tu calendario o base de datos real (Google Calendar, Supabase, etc.).\n// Por ahora devuelve espacios de ejemplo para probar el flujo de punta a punta.\nconst d = $json;\nconst fecha = d.fecha_preferida || '2026-07-15';\nreturn [{\n  json: {\n    disponible: true,\n    especialidad: d.especialidad || null,\n    paciente: d.nombre || null,\n    slots: [\n      { fecha, hora: '10:00', medico: 'Dra. Ana Lopez' },\n      { fecha, hora: '15:30', medico: 'Dra. Ana Lopez' }\n    ],\n    mensaje: 'Hay 2 espacios disponibles.'\n  }\n}];"
      },
      "id": "code-disp",
      "name": "Consultar disponibilidad",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 0]
    },
    {
      "parameters": {
        "respondWith": "firstIncomingItem",
        "options": {}
      },
      "id": "resp-disp",
      "name": "Responder disponibilidad",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [720, 0]
    },
